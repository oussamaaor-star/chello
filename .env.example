VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase — côté serveur uniquement (ne jamais mettre de préfixe VITE_)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Stripe — côté serveur uniquement (pas de préfixe VITE_)
STRIPE_SECRET_KEY=sk_test_...

# Stripe — publishable key (optionnel avec Stripe Hosted Checkout)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe — secret webhook (depuis dashboard Stripe ou stripe listen --print-secret)
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend — service d'email transactionnel (resend.com)
RESEND_API_KEY=re_...

# Email expéditeur (domaine vérifié dans Resend en production)
# En dev : onboarding@resend.dev (pas de vérification requise)
EMAIL_FROM=Parfumerie Marwan <onboarding@resend.dev>

# URL publique du site (pour les liens dans les emails)
SITE_URL=https://ton-projet.vercel.app

# Sentry — monitoring des erreurs front-end (optionnel)
# Créer un projet sur sentry.io → Settings → Client Keys → DSN
VITE_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/yyy

# Version de l'app (optionnel — apparaît dans les releases Sentry)
# VITE_APP_VERSION=1.0.0
