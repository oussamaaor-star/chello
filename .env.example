VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase — côté serveur uniquement (ne jamais mettre de préfixe VITE_)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Resend — service d'email transactionnel (resend.com)
RESEND_API_KEY=re_...

# Email expéditeur (domaine vérifié dans Resend en production)
# En dev : onboarding@resend.dev (pas de vérification requise)
EMAIL_FROM=Chello <onboarding@resend.dev>

# Email de la boutique (réception des messages de contact)
SHOP_EMAIL=contact@chello.example

# URL publique du site (pour les liens dans les emails)
SITE_URL=https://chello-nine.vercel.app

# Sentry — monitoring des erreurs front-end (optionnel)
# Créer un projet sur sentry.io → Settings → Client Keys → DSN
VITE_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/yyy

# Version de l'app (optionnel — apparaît dans les releases Sentry)
# VITE_APP_VERSION=1.0.0
